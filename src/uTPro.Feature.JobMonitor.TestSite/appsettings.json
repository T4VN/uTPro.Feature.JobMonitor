{
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.Hosting.Lifetime": "Information",
        "System": "Warning"
      }
    }
  },
  "Umbraco": {
    "CMS": {
      "Global": {
        "Id": "b8f2d7a1-4c39-4e6b-9a17-2f5c8e0d3b46",
        "SanitizeTinyMce": true
      },
      "Hosting": {
        "Debug": true
      },
      "ModelsBuilder": {
        "ModelsMode": "Nothing"
      },
      "RuntimeMinification": {
        "UseInMemoryCache": true,
        "CacheBuster": "Timestamp"
      },
      "Unattended": {
        "InstallUnattended": true,
        "UnattendedUserName": "Admin",
        "UnattendedUserEmail": "admin@example.com",
        "UnattendedUserPassword": "Admin1234!"
      },
      "Imaging": {
        "HMACSecretKey": "xDHxa4Z6dFwmdBkleKntrvSiQrnqCkEOcxRaRgLqa19nyyZNNxkkr1dgu2FYR1fmoZ4huqFUNr5SrTbAdZ0kMg=="
      }
    }
  },
  "uTPro": {
    "Feature": {
      "JobMonitor": {
        "Storage": "Durable",
        "HistoryCapacity": 100,
        "DiscoveryCacheSeconds": 30
      }
    }
  },
  "ConnectionStrings": {
    "umbracoDbDSN": "Data Source=|DataDirectory|/Umbraco.sqlite.db;Cache=Shared;Foreign Keys=True;Pooling=True",
    "umbracoDbDSN_ProviderName": "Microsoft.Data.Sqlite"
  }
}
